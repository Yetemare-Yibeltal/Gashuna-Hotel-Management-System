# ── Dependencies ──────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build output ──────────────────────────────────────────
client/dist/
client/build/
server/dist/

# ── Environment files — NEVER commit these ────────────────
.env
.env.local
.env.development
.env.production
.env.*.local
client/.env
client/.env.local
server/.env
server/.env.local

# ── Logs ──────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS generated files ────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor files ──────────────────────────────────────────
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── VS Code — keep workspace settings, ignore personal ────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ── TypeScript build info ─────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vite cache ────────────────────────────────────────────
client/.vite/

# ── Upload folders — don't commit uploaded files ──────────
server/src/uploads/

# ── Coverage reports ──────────────────────────────────────
coverage/
*.lcov
