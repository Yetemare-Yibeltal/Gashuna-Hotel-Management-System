# ═══════════════════════════════════════════════════════════
# GASHUNA HOTEL — SERVER ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub — it contains secrets
# ═══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Client URL (for CORS) ───────────────────────────────────
# During development this is the Vite dev server
# In production this is your deployed frontend URL
CLIENT_URL=http://localhost:5173

# ── MongoDB ─────────────────────────────────────────────────
# Get this from MongoDB Atlas — create a free cluster at
# https://www.mongodb.com/cloud/atlas
# Replace <username>, <password>, and <cluster> with yours
MONGODB_URI=mongodb+srv://gashuna_hotel:gashuna_hotel@cluste.4yfft2k.mongodb.net/?appName=Cluste

# ── JWT Authentication ───────────────────────────────────────
# Use a long random string — minimum 32 characters
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# ── Chapa Payment Gateway ────────────────────────────────────
# Get these from your Chapa dashboard at https://dashboard.chapa.co
# Use test keys during development, live keys in production
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret
CHAPA_BASE_URL=https://api.chapa.co/v1

# ── Email (Nodemailer) ───────────────────────────────────────
# Used for sending booking confirmations and invoices
# For development use Mailtrap: https://mailtrap.io
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_mailtrap_username
EMAIL_PASS=your_mailtrap_password
EMAIL_FROM=noreply@gashunahotel.et
EMAIL_FROM_NAME=Gashuna Hotel

# ── File Upload ──────────────────────────────────────────────
# Maximum file size for image uploads (in bytes)
# 5MB = 5 * 1024 * 1024 = 5242880
MAX_FILE_SIZE=5242880
UPLOAD_PATH=src/uploads

# ── Hotel Info ───────────────────────────────────────────────
# Used in emails, invoices, and system notifications
HOTEL_NAME=Gashuna Hotel
HOTEL_ADDRESS=Dangla, Awi Zone, Amhara Region, Ethiopia
HOTEL_PHONE=+251934567890
HOTEL_EMAIL=info@gashunahotel.et
HOTEL_WEBSITE=https://gashunahotel.et
HOTEL_VAT_NUMBER=VAT-ET-0001234
VAT_RATE=0.15

# ── Rate Limiting ────────────────────────────────────────────
# Maximum API requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
