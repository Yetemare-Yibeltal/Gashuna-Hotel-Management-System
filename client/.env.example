# ═══════════════════════════════════════════════════════════
# GASHUNA HOTEL — CLIENT ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub
# ═══════════════════════════════════════════════════════════

# ── API URL ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api

# ── Chapa Public Key ─────────────────────────────────────────
# This is the PUBLIC key only — safe to use in the frontend
# NEVER put your Chapa SECRET key in the frontend
VITE_CHAPA_PUBLIC_KEY=CHAPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Hotel Info ───────────────────────────────────────────────
VITE_HOTEL_NAME=Gashuna Hotel
VITE_HOTEL_LOCATION=Dangla, Awi Zone, Amhara Region, Ethiopia
VITE_HOTEL_PHONE=+251934567890
VITE_HOTEL_EMAIL=info@gashunahotel.et

# ── Currency ─────────────────────────────────────────────────
VITE_CURRENCY=ETB
VITE_VAT_RATE=0.15
